# Program uji coba BahasaFlores

bua sapa(nama):
    bua jadi("Halo " + nama + "!")

bua tambah(a, b):
    beri bale a + b

x = beri maso("Masukkan angka: ")
x = int(x)
nilai = tambah(x, 10)

bua jadi("Hasil: " + str(nilai))

t ada le (nilai > 20):
    bua jadi("Angkanya besar")
kalo ne (nilai == 20):
    bua jadi("Pas dua puluh")
yang lae:
    bua jadi("Angkanya kecil")

unto i dalam range(3):
    bua jadi(i)

puna pali (x > 0):
    bua jadi(x)
    x = x - 1

sapa("Flores")

bua jadi("")
bua jadi("=== Program Selesai ===")
beri maso("Tekan Enter untuk keluar...")